# Copy to .env.local and adjust.

# The birthday, in local date form YYYY-MM-DD. The experience's midnight is 00:00 of this date.
NEXT_PUBLIC_BIRTHDAY=2026-07-15

# Her name, used at the climax.
NEXT_PUBLIC_NAME=Indumathi

# Passcode for the hidden /conductor control panel (manual real-world arrival trigger).
CONDUCTOR_PASSCODE=changeme

# Allow URL-based debug time-travel (?simNow=ISO and ?phase=) even in production.
# Leave unset/false for the real gift. Set to "true" only while previewing.
NEXT_PUBLIC_ALLOW_DEBUG=true
